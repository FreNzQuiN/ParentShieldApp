{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2020"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "resources/js/snailly/*"
            ]
        },
        "allowJs": true,
        "skipLibCheck": true,
        "strict": false,
        "noEmit": true,
        "types": [
            "vite/client"
        ]
    },
    "include": [
        "resources/js/**/*",
        "vite.config.js"
    ]
}